{
  "envId": "<YOUR_CLOUDBASE_ENV_ID>",
  "version": "2.0",
  "framework": {
    "name": "used-car-a2a-vnext",
    "plugins": {
      "container": {
        "use": "@cloudbase/framework-plugin-container",
        "inputs": {
          "serviceName": "used-car-a2a-vnext",
          "servicePath": "/",
          "localPath": "./",
          "containerPort": 80,
          "cpu": 0.5,
          "mem": 1,
          "policy": "PARALLEL",
          "maxCount": 2,
          "minCount": 0,
          "envVariables": {
            "PORT": "80",
            "APP_MODE": "tool"
          }
        }
      }
    }
  }
}
