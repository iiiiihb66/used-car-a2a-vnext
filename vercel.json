{
  "rewrites": [
    {
      "source": "/",
      "destination": "/site/index.html"
    },
    {
      "source": "/skill.md",
      "destination": "/site/skill.md"
    },
    {
      "source": "/.well-known/agent.json",
      "destination": "/site/agent.json"
    }
  ],
  "headers": [
    {
      "source": "/site/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
