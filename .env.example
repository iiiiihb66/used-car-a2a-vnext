# ============ 数据库 ============
# 本地开发可留空，默认使用 SQLite
# 可选：通过 DB_DIR / SQLITE_FILENAME 修改 SQLite 落盘位置
# 例如 DB_DIR=/app/data
# CloudBase SQL / MySQL 示例:
# DATABASE_URL=mysql+pymysql://user:password@host:3306/dbname?charset=utf8mb4
DATABASE_URL=
DB_DIR=
SQLITE_FILENAME=c2c_platform.db
SQLITE_BACKUP_DIR=./backups

# ============ CloudBase AI / OpenAI 兼容模型 ============
# CloudBase OpenAI SDK Base URL 示例:
# https://<ENV_ID>.api.tcloudbasegateway.com/v1/ai/hunyuan/v1
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=hunyuan-turbos-latest

# ============ 服务配置 ============
APP_MODE=tool
ADMIN_TOKEN=
CORS_ORIGINS=*
